# ── SumUp credentials ────────────────────────────────────────────────────────
# Get from https://developer.sumup.com/ → Applications → Client Credentials
SUMUP_API_KEY=sup_sk_xxxxxxxxxxxxxxxxxxxx

# Your merchant code — visible in SumUp dashboard (top-right profile menu)
SUMUP_MERCHANT_CODE=MXXXXXXXX

# Optional: reader device ID for explicit push (e.g. SumUp Solo LTE).
# If omitted, the paired Air/Solo reader auto-polls for PENDING checkouts.
# Find it: SumUp dashboard → Devices, or GET /v0.1/merchants/:code/readers
# SUMUP_READER_ID=XXXXXXXXXXXXXXXX

# ── Printer ──────────────────────────────────────────────────────────────────
# Photobooth unlock endpoint — built into photobooth.py, no config needed
PRINTER_API_URL=http://localhost:8080/unlock

# ── Payment ──────────────────────────────────────────────────────────────────
AMOUNT=100        # cents — 100 = 1.00 €, 200 = 2.00 €
CURRENCY=EUR
DESCRIPTION=Photo

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
POLL_INTERVAL_MS=2000
