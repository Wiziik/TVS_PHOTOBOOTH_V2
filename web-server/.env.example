# ── Server ────────────────────────────────────────────────────────────────
PORT=3100
BASE_URL=https://photos.tvstore.fr
DATA_DIR=/srv/tvs-photobooth/data
PHOTO_DIR=/srv/tvs-photobooth/photos
PHOTO_RETENTION_DAYS=30

# ── Shared secret the Pi uses on /api/upload ──────────────────────────────
# Pi sends:  Authorization: Bearer <UPLOAD_TOKEN>
UPLOAD_TOKEN=change-me-to-a-long-random-string

# ── Mailchimp Marketing ───────────────────────────────────────────────────
# API key format: <hash>-us17 — the -us17 suffix is the data center
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=a697aa242d
MAILCHIMP_TAG=photobooth
